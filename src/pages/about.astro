---
import Layout from '../layouts/Layout.astro';
import profileImage from '../assets/dre.jpeg';
---

<Layout title="Andrea Allodi">
  <!-- Page title -->
  <section class="py-10 md:py-16">
    <h1 class="text-center text-xl md:text-4xl font-normal  tracking-tight">⋆ About me ⋆</h1>
  </section>

  <!-- Bio section -->
  <section class="max-w-5xl mx-auto px-8 md:px-16 pb-20">
    <div class="flex flex-col md:flex-row gap-10 md:gap-16 items-start">
      <!-- Photo -->
      <div class="w-full md:w-1/5 shrink-0">
        <img
          src={profileImage.src}
          alt="Andrea Allodi"
          class="w-full h-auto object-cover"
        />
      </div>
      <!-- Text -->
      <div class="w-full md:w-3/5 text-sm md:text-base font-light leading-relaxed text-gray-700 space-y-4">
        <p>
          I'm a photographer and graphic designer based in Manerba del Garda, Italy (BS) with a passion for urban culture and music.
        </p>
        <p>
          I mainly focus on concert and street photography, capturing the energy of real and spontaneous moments between the stage and the streets. Through my work I try to tell stories and emotions with a raw and authentic style, combining photography and design to create strong visual impact.       
        </p>
      </div>
    </div>
  </section>

  <!-- Contact links -->
  <section class="max-w-2xl mx-auto px-8 pb-24 text-center">
    <h2 class="text-center text-xl md:text-2xl font-normal tracking-tight mb-6">Contact me!</h2>
    <p class="text-sm md:text-base font-light text-gray-700">
      Contact me on the following mail <i> eallo00@gmail.com </i> or on my Instagram <i> @andreaaallodi </i> for any inquiries, collaborations or just to say hi!
    </p>

    <div class="mt-6 flex items-center justify-center gap-5">
      <a
        href="mailto:eaallo00@gmail.com"
        aria-label="Email"
        class="text-gray-600 hover:text-black transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </a>
      <a
        href="https://www.instagram.com/andreaaallodi/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-gray-600 hover:text-black transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
    </div>
  </section>
</Layout>
