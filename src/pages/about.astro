---
import Layout from '../layouts/Layout.astro';
import profileImage from '../assets/test.png';
---

<Layout title="Andrea Allodi">
  <!-- Page title -->
  <section class="py-10 md:py-16">
    <h1 class="text-center text-xl md:text-4xl font-normal font-script tracking-tight">About me</h1>
  </section>

  <!-- Bio section -->
  <section class="max-w-5xl mx-auto px-8 md:px-16 pb-20">
    <div class="flex flex-col md:flex-row gap-10 md:gap-16 items-start">
      <!-- Photo -->
      <div class="w-full md:w-2/5 shrink-0">
        <img
          src={profileImage.src}
          alt="Andrea Allodi"
          class="w-full h-auto object-cover"
        />
      </div>
      <!-- Text -->
      <div class="w-full md:w-3/5 text-sm md:text-base font-light leading-relaxed text-gray-700 space-y-4">
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus lacinia odio vitae vestibulum vestibulum. Cras vehicula, mi eget laoreet venenatis, sem dolor tincidunt neque, a auctor nisi urna at lorem.
        </p>
        <p>
          Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Proin pharetra nonummy pede. Mauris et orci. Aenean nec lorem. In porttitor. Donec laoreet nonummy augue.
        </p>
        <p>
          Suspendisse dui purus, scelerisque at, vulputate vitae, pretium mattis, nunc. Mauris eget neque at sem venenatis eleifend. Ut nonummy. Fusce aliquet pede non pede.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section class="max-w-lg mx-auto px-8 pb-24">
    <h2 class="text-center text-xl md:text-2xl font-normal tracking-tight mb-10">//for contact</h2>

    <form class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-light text-gray-800 mb-2">
          your name <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Il tuo nome e cognome"
          required
          class="w-full border border-gray-800 px-4 py-2.5 text-sm font-light placeholder-gray-400 focus:outline-none focus:border-black"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-light text-gray-800 mb-2">
          your email <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="Il tuo indirizzo email"
          required
          class="w-full border border-gray-800 px-4 py-2.5 text-sm font-light placeholder-gray-400 focus:outline-none focus:border-black"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-light text-gray-800 mb-2">
          message to send <span class="text-red-500">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Il tuo messaggio"
          required
          class="w-full border border-gray-800 px-4 py-2.5 text-sm font-light placeholder-gray-400 focus:outline-none focus:border-black resize-y"
        ></textarea>
      </div>

      <div class="text-center">
        <button
          type="submit"
          class="text-sm font-light text-gray-800 hover:text-black transition-colors underline underline-offset-4"
        >
          send
        </button>
      </div>
    </form>
  </section>
</Layout>
