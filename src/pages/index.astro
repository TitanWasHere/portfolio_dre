---
import Layout from '../layouts/Layout.astro';
import heroImage from '../assets/test.png';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Andrea Allodi" bare>
  <section class="relative w-full h-screen overflow-hidden">
    <!-- Hero image -->
    <img
      src={heroImage.src}
      alt="Andrea Allodi"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Overlay content -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-white">
      <h1 class="text-4xl md:text-6xl font-light tracking-wide mb-12">Andrea Allodi</h1>
      <a
        href={`${base}/photos`}
        class="border border-white/60 px-8 py-3 text-sm font-light tracking-widest hover:bg-white/10 transition-colors"
      >
        //discover
      </a>
    </div>

    <!-- Bottom Instagram icon -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <a href="#" aria-label="Instagram" class="text-white/80 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
    </div>
  </section>
</Layout>