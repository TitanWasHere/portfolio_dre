---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('graphics');
  return entries.map((entry) => ({
    params: { id: entry.id.replace(/\.md$/, '') },
    props: { entry, collection: 'graphics' },
  }));
}

const { entry, collection } = Astro.props;
const { title, images, date } = entry.data;
const year = date.getFullYear();
const backLink = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/graphics`;

const allEntries = await getCollection('graphics');
const others = allEntries.filter((e) => e.id !== entry.id);
const recommended = others.length > 0
  ? others[Math.floor(Math.random() * others.length)]
  : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${title} — Andrea Allodi`}>
  <!-- Header -->
  <section class="py-10 md:py-16 text-center">
    <h1 class="text-2xl md:text-4xl font-normal tracking-tight font-script">{title}</h1>
    <p class="text-xs text-gray-400 mt-2">{year}</p>
  </section>

  <!-- Masonry gallery -->
  <section class="max-w-6xl mx-auto px-6 md:px-12 pb-24 columns-1 sm:columns-2 lg:columns-3 gap-2 space-y-2">
    {images.map((img, i) => (
      <div class="break-inside-avoid">
        <Image
          src={img}
          alt={`${title} — foto ${i + 1}`}
          width={800}
          height={800}
          class="w-full h-auto object-cover cursor-pointer hover:opacity-90 transition-opacity lightbox-img"
        />
      </div>
    ))}
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-8 cursor-pointer">
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain" />
  </div>

  <!-- Recommended -->
  {recommended && (
    <section class="max-w-4xl mx-auto px-6 md:px-12 pb-16">
      <h3 class="text-center text-sm text-gray-400 mb-8 tracking-wide">Check something else ;)</h3>
      <a href={`${base}/album/graphics/${recommended.id.replace(/\.md$/, '')}`} class="block group">
        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12">
          <div class="w-full md:w-1/2 overflow-hidden relative">
            <Image
              src={recommended.data.images[0]}
              alt={recommended.data.title}
              width={600}
              height={400}
              class="w-full h-auto object-cover transition-all duration-500"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-500"></div>
          </div>
          <div class="text-center md:text-left">
            <h4 class="text-lg md:text-xl font-normal text-gray-800 font-script transition-transform duration-500 md:origin-left group-hover:scale-105">
              {recommended.data.title}
            </h4>
            <p class="text-xs text-gray-400 mt-1">{recommended.data.date.getFullYear()}</p>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- Back link -->
  <div class="text-center pb-16">
    <a href={backLink} class="text-sm font-light text-gray-500 hover:text-black transition-colors">
      &larr; back
    </a>
  </div>
</Layout>

<script>
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const images = document.querySelectorAll(".lightbox-img");

  images.forEach((img) => {
    img.addEventListener("click", () => {
      const src = (img as HTMLImageElement).src;
      const alt = (img as HTMLImageElement).alt;
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox?.classList.remove("hidden");
      lightbox?.classList.add("flex");
    });
  });

  lightbox?.addEventListener("click", (e) => {
    if (e.target !== lightboxImg) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      lightbox?.classList.add("hidden");
      lightbox?.classList.remove("flex");
    }
  });
</script>
