---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const entries = (await getCollection('photos'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Andrea Allodi">
  <section class="py-10 md:py-16">
    <h1 class="text-center text-xl md:text-4xl font-normal font-script tracking-tight">Photos</h1>
  </section>

  <section class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 pb-24 space-y-12 md:space-y-10">
    {entries.map((entry, i) => {
      const isEven = i % 2 === 0;
      const year = entry.data.date.getFullYear();
      const cover = entry.data.images[0];
      return (
        <a href={`${base}/album/photos/${entry.id.replace(/\.md$/, '')}`} class="block group">
          <article class={`flex flex-col ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-8 md:gap-16`}>
            <div class="w-full md:w-[55%] overflow-hidden relative">
              <Image
                src={cover}
                alt={entry.data.title}
                width={700}
                height={500}
                class="w-full h-auto object-cover transition-all duration-500"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-500"></div>
            </div>
            <div class={`w-full md:w-[45%] ${isEven ? 'md:text-left' : 'md:text-right'} text-center`}>
              <h2 class={`text-lg md:text-xl font-normal leading-relaxed text-gray-800 font-script transition-transform duration-500 group-hover:scale-105 ${isEven ? 'md:origin-left' : 'md:origin-right'}`}>
                {entry.data.title}
              </h2>
              <p class="text-xs text-gray-400 mt-1">{year}</p>
            </div>
          </article>
        </a>
      );
    })}
  </section>
</Layout>
